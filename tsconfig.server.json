{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist-server",
    "rootDir": ".",
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "declaration": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "server/**/*",
    "types.ts",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-server",
    "components",
    "pages",
    "hooks",
    "services",
    "schemas",
    "utils",
    "smartclaim-ai-agent",
    "adjuster-workbench",
    "wechat-miniprogram"
  ]
}
