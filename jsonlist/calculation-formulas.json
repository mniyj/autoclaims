  "AUTO_DAMAGE": {
    "description": "车辆损失理算",
    "insuranceType": "AUTO",
    "formula": "min(repair_cost, actual_value) * liability_ratio",
    "variables": {
      "repair_cost": {
        "source": "claim.repair_estimate",
        "type": "number",
        "label": "定损金额"
      },
      "actual_value": {
        "source": "vehicle.actual_value",
        "type": "number",
        "label": "车辆实际价值"
      },
      "liability_ratio": {
        "source": "claim.liability_ratio",
        "type": "number",
        "label": "责任比例"
      }
    },
    "steps": [
      {
        "name": "取定损与价值较小值",
        "expr": "min(repair_cost, actual_value)",
        "output": "base_amount"
      },
      {
        "name": "应用责任比例",
        "expr": "base_amount * liability_ratio",
        "output": "final_amount"
      }
    ],
    "output": {
      "field": "final_amount",
      "type": "number",
      "label": "车损理赔金额"
    }
  },

  "AUTO_INJURY": {
    "description": "车上人员伤亡理算",
    "insuranceType": "AUTO",
    "formula": "sum_insured * grade_ratio",
    "variables": {
      "sum_insured": {
        "source": "coverage.per_seat_sum_insured",
        "type": "number",
        "label": "每座保额"
      },
      "grade_ratio": {
        "source": "lookup",
        "lookup_table": "injury_grade_table",
        "lookup_key": "claim.injury_grade",
        "type": "number",
        "label": "伤亡等级比例"
      }
    },
    "lookup_tables": {
      "injury_grade_table": {
        "死亡": 1.0,
        "重伤": 0.8,
        "轻伤": 0.3
      }
    },
    "steps": [
      {
        "name": "查询伤亡比例",
        "expr": "grade_ratio",
        "output": "grade_ratio"
      },
      {
        "name": "计算给付金额",
        "expr": "sum_insured * grade_ratio",
        "output": "final_amount"
      }
    ],
    "output": {
      "field": "final_amount",
      "type": "number",
      "label": "人员伤亡理赔金额"
    }
  },

  "LIABILITY_DEATH": {
    "description": "责任险死亡赔偿理算（HYBRID模式）",
    "insuranceType": "LIABILITY",
    "formula": "max((death_compensation + funeral_expense + dependent_expense + medical_expense) * liability_ratio - paid_offset, 0)",
    "variables": {
      "death_compensation": {
        "source": "claim.death_compensation",
        "type": "number",
        "label": "死亡赔偿金"
      },
      "funeral_expense": {
        "source": "claim.funeral_expense",
        "type": "number",
        "label": "丧葬费"
      },
      "dependent_expense": {
        "source": "claim.dependent_expense",
        "type": "number",
        "label": "被扶养人生活费"
      },
      "medical_expense": {
        "source": "claim.medical_expense",
        "type": "number",
        "label": "抢救/治疗医疗费用"
      },
      "liability_ratio": {
        "source": "claim.liability_ratio",
        "type": "number",
        "label": "责任比例"
      },
      "paid_offset": {
        "source": "claim.paid_offset",
        "type": "number",
        "label": "已付金额抵扣"
      }
    },
    "steps": [
      {
        "name": "汇总损失项目",
        "expr": "death_compensation + funeral_expense + dependent_expense + medical_expense",
        "output": "total_loss"
      },
      {
        "name": "应用责任比例",
        "expr": "total_loss * liability_ratio",
        "output": "liable_amount"
      },
      {
        "name": "扣除已付抵扣",
        "expr": "liable_amount - paid_offset",
        "output": "net_amount"
      },
      {
        "name": "确保非负",
        "expr": "max(net_amount, 0)",
        "output": "final_amount"
      }
    ],
    "output": {
      "field": "final_amount",
      "type": "number",
      "label": "责任赔偿金额"
    }
  },

  "LIABILITY_INJURY": {
    "description": "责任险人身伤害（非死亡）理算",
    "insuranceType": "LIABILITY",
    "formula": "max(medical_expense * liability_ratio - paid_offset, 0)",
    "variables": {
      "medical_expense": {
        "source": "claim.medical_expense",
        "type": "number",
        "label": "医疗费用"
      },
      "liability_ratio": {
        "source": "claim.liability_ratio",
        "type": "number",
        "label": "责任比例"
      },
      "paid_offset": {
        "source": "claim.paid_offset",
        "type": "number",
        "label": "已付金额抵扣"
      }
    },
    "steps": [
      {
        "name": "应用责任比例",
        "expr": "medical_expense * liability_ratio",
        "output": "liable_amount"
      },
      {
        "name": "扣除已付抵扣",
        "expr": "liable_amount - paid_offset",
        "output": "net_amount"
      },
      {
        "name": "确保非负",
        "expr": "max(net_amount, 0)",
        "output": "final_amount"
      }
    ],
    "output": {
      "field": "final_amount",
      "type": "number",
      "label": "人身伤害赔偿金额"
    }
  },

  "LIABILITY_PROPERTY": {
    "description": "责任险财产损失理算",
    "insuranceType": "LIABILITY",
    "formula": "min(property_loss * liability_ratio, per_incident_limit) - paid_offset",
    "variables": {
      "property_loss": {
        "source": "claim.property_loss",
        "type": "number",
        "label": "财产损失金额"
      },
      "liability_ratio": {
        "source": "claim.liability_ratio",
        "type": "number",
        "label": "责任比例"
      },
      "per_incident_limit": {
        "source": "coverage.per_incident_limit",
        "type": "number",
        "label": "每次事故限额"
      },
      "paid_offset": {
        "source": "claim.paid_offset",
        "type": "number",
        "label": "已付金额抵扣"
      }
    },
    "steps": [
      {
        "name": "应用责任比例",
        "expr": "property_loss * liability_ratio",
        "output": "liable_amount"
      },
      {
        "name": "应用每次事故限额",
        "expr": "min(liable_amount, per_incident_limit)",
        "output": "capped_amount"
      },
      {
        "name": "扣除已付抵扣",
        "expr": "capped_amount - paid_offset",
        "output": "net_amount"
      },
      {
        "name": "确保非负",
        "expr": "max(net_amount, 0)",
        "output": "final_amount"
      }
    ],
    "output": {
      "field": "final_amount",
      "type": "number",
      "label": "责任财产赔偿金额"
    }
  }
}
