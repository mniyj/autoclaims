  "AUTO_DAMAGE": {
    "description": "车辆损失理算",
    "insuranceType": "AUTO",
    "formula": "min(repair_cost, actual_value) * liability_ratio",
    "variables": {
      "repair_cost": {
        "source": "claim.repair_estimate",
        "type": "number",
        "label": "定损金额"
      },
      "actual_value": {
        "source": "vehicle.actual_value",
        "type": "number",
        "label": "车辆实际价值"
      },
      "liability_ratio": {
        "source": "claim.liability_ratio",
        "type": "number",
        "label": "责任比例"
      }
    },
    "steps": [
      {
        "name": "取定损与价值较小值",
        "expr": "min(repair_cost, actual_value)",
        "output": "base_amount"
      },
      {
        "name": "应用责任比例",
        "expr": "base_amount * liability_ratio",
        "output": "final_amount"
      }
    ],
    "output": {
      "field": "final_amount",
      "type": "number",
      "label": "车损理赔金额"
    }
  },

  "AUTO_INJURY": {
    "description": "车上人员伤亡理算",
    "insuranceType": "AUTO",
    "formula": "sum_insured * grade_ratio",
    "variables": {
      "sum_insured": {
        "source": "coverage.per_seat_sum_insured",
        "type": "number",
        "label": "每座保额"
      },
      "grade_ratio": {
        "source": "lookup",
        "lookup_table": "injury_grade_table",
        "lookup_key": "claim.injury_grade",
        "type": "number",
        "label": "伤亡等级比例"
      }
    },
    "lookup_tables": {
      "injury_grade_table": {
        "死亡": 1.0,
        "重伤": 0.8,
        "轻伤": 0.3
      }
    },
    "steps": [
      {
        "name": "查询伤亡比例",
        "expr": "grade_ratio",
        "output": "grade_ratio"
      },
      {
        "name": "计算给付金额",
        "expr": "sum_insured * grade_ratio",
        "output": "final_amount"
      }
    ],
    "output": {
      "field": "final_amount",
      "type": "number",
      "label": "人员伤亡理赔金额"
    }
  }
}
