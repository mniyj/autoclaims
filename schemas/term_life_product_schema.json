{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "定期寿险产品数据结构 (Term Life Insurance Product Schema)",
  "description": "用于定义定期寿险产品的完整数据结构，覆盖基础信息、专属字段、核心的身故/全残保障责任以及可选的豁免/额外赔付责任。",
  "type": "object",

  "properties": {
    "coveragePlans": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "planType": { "type": "string" },
          "coverageDetails": {
            "type": "array",
            "items": { "$ref": "#/$defs/CoverageDetailItem" }
          }
        },
        "required": ["planType", "coverageDetails"]
      }
    },
    "productCode": {
      "type": "string",
      "description": "产品的唯一标识码，不可编辑。"
    },
    "regulatoryName": {
      "type": "string",
      "description": "监管机构备案的正式名称。"
    },
    "marketingName": {
      "type": "string",
      "description": "市场推广时使用的名称。"
    },
    "productSummery": {
      "type": "string",
      "description": "产品摘要，突出卖点。"
    },
    "onlineClaimFlag": {
      "type": "boolean",
      "description": "是否支持在线理赔。"
    },
    "insurerName": {
      "type": "string",
      "description": "所属保险公司名称。"
    },
    "version": {
      "type": "string",
      "description": "产品版本号。"
    },
    "salesRegions": {
      "type": "string",
      "description": "产品的销售区域。"
    },
    "effectiveDate": {
      "type": "string",
      "format": "date",
      "description": "产品生效日期 (格式: YYYY-MM-DD)。"
    },
    "expiryDate": {
      "type": ["string", "null"],
      "format": "date",
      "description": "产品停售日期 (格式: YYYY-MM-DD)，如果未停售则为 null。"
    },
    "status": {
      "type": "string",
      "enum": ["生效", "失效", "草稿"],
      "description": "产品状态。"
    },
    "primaryCategory": {
      "type": "string",
      "description": "产品一级分类名称（如：人寿保险）。"
    },
    "primaryCategoryCode": {
      "type": "string",
      "description": "产品一级分类代码（如：F）。"
    },
    "secondaryCategory": {
      "type": "string",
      "description": "产品二级分类名称（如：定期寿险）。"
    },
    "secondaryCategoryCode": {
      "type": "string",
      "description": "产品二级分类代码（如：F01）。"
    },
    "racewayId": {
      "type": "string",
      "description": "三级赛道编码（如：F0101）。"
    },
    "racewayName": {
      "type": "string",
      "description": "三级赛道名称（如：定期寿险）。"
    },
    "salesUrl": {
      "type": "string",
      "format": "uri",
      "description": "销售落地页的 URL 地址。"
    },
    "underwritingAge": {
      "type": "string",
      "description": "投保年龄范围描述。"
    },
    "coveragePeriod": {
      "type": "string",
      "description": "保障期限描述（如：保20年、保至60岁）。"
    },
    "waitingPeriod": {
      "type": "string",
      "description": "等待期描述（如：90天、180天）。"
    },
    "deductible": {
      "type": "string",
      "description": "免赔额描述（定期寿险通常为0或不适用）。"
    },
    "productHeroImage": {
      "type": "string",
      "format": "uri",
      "description": "产品卡片和详情页的头图 URL。"
    },
    "productLongImage": {
      "type": "array",
      "description": "产品介绍长图，用于详情页。",
      "items": { "type": "string" }
    },
    "productAttachment": {
      "type": "array",
      "items": { "type": "string" },
      "description": "产品相关附件的文件名列表。"
    },
    "clausesCode": {
      "type": "array",
      "items": { "type": "string" },
      "description": "产品条款代码列表。"
    },
    "productIntroduction": { "type": "string", "description": "产品的详细介绍文案。" },
    "productAdvantages": { "type": "string", "description": "产品优势的文本描述。" },
    "precautions": { "type": "string", "description": "产品注意事项的文本描述（通常包含免责条款）。" },
    "crowd": { "type": "string", "description": "产品适用人群的文本描述。" },
    "generalComment": { "type": "string", "description": "产品的总评或专家点评。" },
    "tags": { "type": "string", "description": "产品的标签，如“金选”。" },
    
    "basicSumAssured": {
      "type": "string",
      "description": "可投保的基础保险金额范围描述。例如: '10万-350万'"
    },
    "paymentPeriod": {
      "type": "string",
      "description": "缴纳保费的年限或方式。例如: '10/20/30年/交至60岁'"
    },
    "underwritingOccupation": {
      "type": "string",
      "description": "承保的职业范围描述。例如: '1-6类职业，高危职业除外'"
    },

    "coverageDetails": {
      "type": "array",
      "description": "保障责任详情列表。",
      "items": { "$ref": "#/$defs/CoverageDetailItem" }
    }
  },
  "required": [
    "productCode", "regulatoryName", "marketingName", "insurerName", "underwritingAge", "coveragePeriod", "waitingPeriod", "basicSumAssured", "paymentPeriod", "underwritingOccupation", "coveragePlans"
  ],

  "$defs": {
    "CoverageDetailItem": {
      "type": "object",
      "description": "单个保障责任项目，如身故/全残、特定意外额外赔、猝死、豁免等。",
      "properties": {
        "mandatory": { "type": "boolean", "description": "是否为必选责任（true=必选，false=可选）。" },
        "item_code": {
          "type": "string",
          "description": "保障项目的内部代码，用于系统识别。",
          "enum": [
            "DEATH_OR_TOTAL_DISABILITY",
            "SPECIFIC_ACCIDENT",
            "SUDDEN_DEATH",
            "INSURED_PREMIUM_WAIVER"
          ]
        },
        "item_name": { "type": "string", "description": "保障项目的名称。" },
        "description": { "type": "string", "description": "保障项目的简要描述。" },
        "details": {
          "type": "object",
          "description": "保障项目的详细参数。结构根据 item_code 不同而变化。",
          "properties": {
            "payout_logic": { "type": "string", "description": "身故/全残的赔付逻辑文本描述，如“赔付100%基本保额”。" },
            "scenario": { "type": "string", "description": "特定意外的场景描述，如“法定节假日航空/公共交通意外”。" },
            "payout_multiplier": { "type": "number", "description": "额外赔付的倍数，如2.0。" },
            "additional_limit": { "type": "integer", "description": "额外赔付的最高限额（元）。" },
            "trigger_events": { "type": "array", "items": { "type": "string" }, "description": "豁免责任的触发事件列表。" }
          }
        }
      },
      "required": ["item_code", "item_name", "description", "details"]
    }
  }
}
