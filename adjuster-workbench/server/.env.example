# WebSocket服务端口
WS_PORT=3007

# 钉钉机器人Webhook URL
# 从钉钉群设置 -> 智能群助手 -> 添加机器人 -> Webhook 获取
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN

# 钉钉机器人安全密钥（可选）
# 用于验证消息来源
DINGTALK_SECRET=YOUR_SECRET

# 数据库配置（后续迁移到数据库时使用）
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insurance_claims
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Redis配置（可选，用于消息队列）
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
